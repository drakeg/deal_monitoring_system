---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mad Mallard Deals',
  description = 'Curated deals for RV travel, fitness, tech, and creator gear.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/placeholder.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a href="/" class="logo">Mad Mallard Deals</a>
        <nav class="nav-links" aria-label="Primary navigation">
          <a href="/adventures">Adventures</a>
          <a href="/personal-training">Personal Training</a>
          <a href="/solutions">Solutions</a>
          <a href="/prime-day">Prime Day</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="container">
        <p>© {new Date().getFullYear()} Mad Mallard Deals. Curated picks across the Mad Mallard brands.</p>
      </div>
    </footer>
  </body>
</html>
