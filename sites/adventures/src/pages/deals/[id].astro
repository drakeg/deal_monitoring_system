---
import BaseLayout from '../../layouts/BaseLayout.astro';
import deals from '../../data/deals.json';

export function getStaticPaths() {
  return deals.map((deal) => ({
    params: { id: deal.id },
    props: { deal },
  }));
}

const { deal } = Astro.props;
---

<BaseLayout title={deal.title}>
  <section class="section detail">
    <p class="eyebrow">{deal.category}</p>
    <h1>{deal.title}</h1>
    <img src={deal.imageUrl} alt="" loading="lazy" />
    <p>{deal.whyItMatters}</p>

    <div class="badges">
      <span class="badge score">Score {deal.dealScore}</span>
      <span class="badge">{deal.price}</span>
      {deal.discount && <span class="badge">{deal.discount} off</span>}
    </div>

    <a class="button" href={deal.affiliateUrl} target="_blank" rel="sponsored noopener">
      Check deal
    </a>
  </section>
</BaseLayout>